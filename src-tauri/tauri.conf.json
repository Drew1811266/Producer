{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Producer",
  "version": "0.1.0",
  "identifier": "com.producer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "frontend-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Producer",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
